ranked-context.json
discoveries/

# OS / editor
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# user config (real paths — never commit)
config/vaultflow.yaml
config/vaultflow.local.yaml

# auto-generated per-user context files (regenerated by gen-context.mjs)
# Contain the user's vault paths; must never be committed.
AGENTS.md
.github/copilot-instructions.md
.cursor/rules/wiki.mdc
.vscode/mcp.json
.mcp.json

# audit / planning docs that bake in user-specific paths
AUDIT-FINDINGS.md
AUDIT-FIX-PLAN.md

# env / secrets
.env
.env.*

# claude-mem audit research scrapes (large; reproducible from web)
.firecrawl/

# claude code session lock + per-machine settings
.claude/scheduled_tasks.lock
.claude/settings.local.json
.debug-hook.log
