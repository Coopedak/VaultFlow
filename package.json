{
  "name": "vaultflow",
  "version": "1.6.0",
  "description": "Claude Code intelligence layer — session tracking, FTS5 memory, skill routing, DISCOVERY pipeline",
  "type": "module",
  "bin": {
    "vault": "./scripts/cli.mjs",
    "vaultflow": "./scripts/cli.mjs"
  },
  "scripts": {
    "setup": "node scripts/install.mjs",
    "setup:dry-run": "node scripts/install.mjs --dry-run",
    "setup:hooks-only": "node scripts/install.mjs --hooks-only",
    "setup:uninstall": "node scripts/install.mjs --uninstall",
    "audit": "node .claude/helpers/audit.mjs",
    "audit:fix": "node .claude/helpers/audit.mjs --fix",
    "lint": "node .claude/helpers/lint.mjs",
    "lint:fix": "node .claude/helpers/lint.mjs --fix",
    "plan": "node .claude/helpers/plan-init.mjs",
    "plan:dir": "node .claude/helpers/plan-init.mjs --list",
    "backfill": "node .claude/helpers/backfill.mjs",
    "backfill:cli-telemetry": "node .claude/helpers/cli-telemetry-backfill.mjs",
    "project-audit": "node .claude/helpers/project-audit.mjs",
    "flush": "node .claude/helpers/flush-parquet.mjs",
    "nightly": "node .claude/helpers/nightly.mjs",
    "doctor": "node .claude/helpers/doctor.mjs",
    "nightly:dry-run": "node .claude/helpers/nightly.mjs --dry-run",
    "nightly:install": "node scripts/run-ps1.mjs .claude/helpers/install-nightly-task.ps1 -RunNow",
    "embeddings:backfill": "node --input-type=module -e \"import('./.claude/helpers/embeddings.mjs').then(m => m.backfillEmbeddings().then(r => console.log(JSON.stringify(r))))\"",
    "embeddings:stats": "node --input-type=module -e \"import('./.claude/helpers/embeddings.mjs').then(m => m.stats().then(r => console.log(JSON.stringify(r))))\"",
    "commits:index": "node -e \"const ci=require('./.claude/helpers/commit-indexer.cjs');const db=require('./.claude/helpers/db.cjs');db.initialize();console.log(JSON.stringify(ci.indexAllProjects(db,'C:/GIT')));db.close();\"",
    "nightly:uninstall": "node scripts/run-ps1.mjs .claude/helpers/install-nightly-task.ps1 -Uninstall",
    "status": "node .claude/helpers/watcher.mjs --status",
    "dashboard": "node .claude/helpers/dashboard/gen.mjs",
    "dashboard:open": "node .claude/helpers/dashboard/gen.mjs --open",
    "dashboard:serve": "node .claude/helpers/dashboard/server.mjs",
    "dashboard:desktop:build": "dotnet build desktop/VaultFlow.DashboardLauncher/VaultFlow.DashboardLauncher.csproj",
    "dashboard:desktop:publish": "dotnet publish desktop/VaultFlow.DashboardLauncher/VaultFlow.DashboardLauncher.csproj -c Release",
    "dashboard:desktop:shortcut": "node scripts/run-ps1.mjs scripts/create-dashboard-shortcut.ps1",
    "claude:tracked": "node scripts/tracked-cli.mjs claude",
    "copilot:tracked": "node scripts/tracked-cli.mjs copilot",
    "codex:tracked": "node scripts/tracked-cli.mjs codex",
    "copilot:tracked:shortcut": "node scripts/run-ps1.mjs scripts/create-tracked-copilot-shortcut.ps1",
    "watcher": "node .claude/helpers/watcher.mjs",
    "watcher:stop": "node .claude/helpers/watcher.mjs --stop",
    "dict": "node .claude/helpers/dict.mjs",
    "dict:import": "node .claude/helpers/dict.mjs --import",
    "import-chats": "node .claude/helpers/import-claude-chats.mjs",
    "import-chats:dry-run": "node .claude/helpers/import-claude-chats.mjs --dry-run",
    "gen-context": "node .claude/helpers/gen-context.mjs",
    "install-hooks": "node .claude/helpers/install-git-hooks.mjs",
    "install-shell-tracker": "node scripts/install-shell-tracker.mjs",
    "install-shell-tracker:check": "node scripts/install-shell-tracker.mjs --check",
    "install-shell-tracker:uninstall": "node scripts/install-shell-tracker.mjs --uninstall",
    "test": "node --test --test-isolation=none --test-concurrency=1 tests/*.test.mjs",
    "model-status": "node .claude/helpers/model-router.cjs --status",
    "mcp-server": "node .claude/helpers/mcp-server.cjs",
    "tui": "node tui/index.mjs",
    "tui:dev": "node --enable-source-maps tui/index.mjs"
  },
  "dependencies": {
    "@duckdb/node-api": "^1.5.2-r.1",
    "blessed": "^0.1.81",
    "chokidar": "^3.6.0",
    "express": "^4.18.2",
    "glob": "^10.3.10",
    "js-yaml": "^4.1.0",
    "node-pty": "^1.1.0"
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.2",
    "sharp": "^0.33.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT"
}
