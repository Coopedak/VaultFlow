{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node C:\\GIT\\vaultflow\\.claude\\helpers\\hook-handler.cjs pre-bash"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node C:\\GIT\\vaultflow\\.claude\\helpers\\post-edit.cjs"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node C:\\GIT\\vaultflow\\.claude\\helpers\\hook-handler.cjs route"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node C:\\GIT\\vaultflow\\.claude\\helpers\\hook-handler.cjs session-start"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node C:\\GIT\\vaultflow\\.claude\\helpers\\hook-handler.cjs session-restore"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node C:\\GIT\\vaultflow\\.claude\\helpers\\hook-handler.cjs session-end"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node C:\\GIT\\vaultflow\\.claude\\helpers\\hook-handler.cjs post-task"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node C:\\GIT\\vaultflow\\.claude\\helpers\\hook-handler.cjs compact-manual"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node C:\\GIT\\vaultflow\\.claude\\helpers\\hook-handler.cjs compact-auto"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node C:\\GIT\\vaultflow\\.claude\\helpers\\hook-handler.cjs post-subagent"
          }
        ]
      }
    ]
  },
  "denyList": [
    "Read(./.env)",
    "Read(./.env.*)",
    "Bash(rm -rf /)"
  ]
}
