{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/GIT/vaultflow/.claude/helpers/pre-read.cjs"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/GIT/vaultflow/.claude/helpers/hook-handler.cjs pre-skill"
          }
        ]
      }
    ]
  },
  "denyList": [
    "Read(./.env)",
    "Read(./.env.*)",
    "Bash(rm -rf /)"
  ]
}
